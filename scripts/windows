#!/usr/bin/env fish

# Manages the Windows 11 VM lifecycle:
#   - Start: brings up the libvirt network, boots the VM, starts scream and
#            looking-glass together. Scream is killed automatically when
#            looking-glass closes.
#   - Stop:  shuts down the VM and kills any leftover scream receiver.

set PID_FILE /tmp/scream.pid

function start_vm
    # Boot the VM first — QEMU creates /dev/shm/scream-ivshmem on start
    echo "Starting Windows 11 VM..."
    sudo virsh start win11

    # Wait for virbr0 to be fully bridged before binding scream to it.
    for i in (seq 10)
        if ip link show virbr0 2>/dev/null | grep -q 'state UP'
            break
        end
        sleep 1
    end

    # Start scream in the background. Skip if already running.
    if pgrep -x scream >/dev/null
        echo "Scream receiver already running, skipping."
    else
        echo "Starting scream audio receiver..."
        scream -i virbr0 -o pulse &
        echo $last_pid >$PID_FILE
    end

    # Wait for the Looking Glass host to come up inside Windows before connecting.
    # Increase this if looking-glass fails to connect on first try.
    echo "Waiting for Windows to boot..."
    sleep 5

    # Run looking-glass in the foreground. When the window is closed, we
    # automatically kill scream so it doesn't linger as an orphan process.
    echo "Launching Looking Glass..."
    looking-glass-client

    # looking-glass exited — tear down scream
    echo "Looking Glass closed. Stopping scream audio receiver..."
    if test -f $PID_FILE
        kill (cat $PID_FILE) 2>/dev/null
        rm $PID_FILE
    end
    pkill -x scream 2>/dev/null
end

function stop_vm
    echo "Shutting down Windows 11 VM..."
    sudo virsh shutdown win11

    # Kill scream by PID file, with pkill as fallback for orphaned instances
    if test -f $PID_FILE
        echo "Stopping scream audio receiver (PID "(cat $PID_FILE)")..."
        kill (cat $PID_FILE) 2>/dev/null
        rm $PID_FILE
    end
    if pgrep -x scream >/dev/null
        echo "Killing orphaned scream instances..."
        pkill -x scream
    end
end

# --- entry point ---

if contains -- --stop $argv
    stop_vm
else
    start_vm
end
